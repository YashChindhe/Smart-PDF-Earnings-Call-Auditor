# OpenRouter / LLM Configuration
# Set OPENROUTER_API_KEY to route requests via OpenRouter for free models
OPENROUTER_API_KEY=your-openrouter-key-here
LLM_MODEL=google/gemini-2.5-flash:free
LLM_API_BASE=https://openrouter.ai/api/v1

# Neon Postgres Database URL (or leave blank to fallback to local SQLite)
DATABASE_URL=postgresql://user:password@ep-something.us-east-2.aws.neon.tech/neondb?sslmode=require

# LiteLLM Local Proxy (Optional: set to true if running local LiteLLM server)
USE_LITELLM_PROXY=false
LITELLM_MODEL=groq/llama3-8b

# LangChain Tracing / telemetry (Optional)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_PROJECT=Earnings-Call-Auditor
LANGCHAIN_API_KEY=your-langsmith-key-here
